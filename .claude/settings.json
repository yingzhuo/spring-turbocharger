{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"model": "haiku",
	"permissions": {
		"allow": [
			"Read",
			"Write",
			"Bash(git *)",
			"Bash(java *)",
			"Bash(javac *)",
			"Bash(./gradlew *)",
			"WebFetch"
		],
		"deny": [
			"Bash(rm -rf *)",
			"Bash(git push --force *)"
		]
	},
	"alwaysThinkingEnabled": true,
	"effortLevel": "medium",
	"language": "chinese",
	"theme": "dark",
	"env": {}
}
